SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
PORT=3001

FOOTBALL_DATA_API_KEY=YOUR_FOOTBALL_DATA_API_KEY

# Used by packages/types to regenerate DB types.
# Run `bun run gen` inside packages/types after any schema change.
# Find your project ID in the Supabase dashboard → Settings → General.
SUPABASE_PROJECT_ID=YOUR_SUPABASE_PROJECT_ID

# Admin credentials (DEC-018 — env-var admin auth replaces the prior is_global_admin DB flag).
# The dedicated admin app (apps/admin) POSTs email+password to /api/admin/login;
# the API verifies against these vars and issues an HMAC-signed JWT (8h expiry).
#
# ADMIN_PASSWORD_HASH is a bcrypt hash — generate with:
#   bun -e "console.log(require('bcrypt').hashSync('your-password', 10))"
# ADMIN_JWT_SECRET signs admin tokens — generate with:
#   openssl rand -hex 32
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=YOUR_BCRYPT_HASH
ADMIN_JWT_SECRET=YOUR_32_BYTE_HEX_SECRET
