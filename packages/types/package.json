{
  "name": "@fuut/types",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "gen": "supabase gen types typescript --project-id \"${SUPABASE_PROJECT_ID:?SUPABASE_PROJECT_ID is not set}\" 2>/dev/null > src/database.types.ts"
  },
  "devDependencies": {
    "supabase": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
